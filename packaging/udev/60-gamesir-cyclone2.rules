# GameSir Cyclone 2 — grant the active desktop user access to the vendor HID node.
# `uaccess` lets systemd-logind hand the device to the active-seat user via an ACL;
# it is distro-agnostic and needs no extra group (the Debian-only `plugdev` group
# does not exist on Arch/CachyOS and made the whole rule line fail there).
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="3537", ATTRS{idProduct}=="100b", TAG+="uaccess"
# DS4 mode: the controller enumerates as a Sony DualShock 4; battery is read via a vendor feature report
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="09cc", TAG+="uaccess"
