<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <enum id="org.gnome.shell.extensions.cyclone2-battery.display-mode">
    <value nick="icon-only" value="0"/>
    <value nick="icon-text" value="1"/>
  </enum>
  <schema id="org.gnome.shell.extensions.cyclone2-battery"
          path="/org/gnome/shell/extensions/cyclone2-battery/">
    <key name="display-mode" enum="org.gnome.shell.extensions.cyclone2-battery.display-mode">
      <default>"icon-text"</default>
      <summary>Top-bar display mode</summary>
    </key>
    <key name="poll-interval" type="i">
      <default>60</default>
      <summary>Battery poll interval in seconds</summary>
    </key>
    <key name="low-battery-threshold" type="i">
      <default>20</default>
      <range min="0" max="50"/>
      <summary>Low-battery notification threshold (percent; 0 disables)</summary>
    </key>
    <key name="level-high-threshold" type="i">
      <default>60</default>
      <range min="0" max="100"/>
      <summary>Battery % at or above which the icon is green</summary>
    </key>
    <key name="level-low-threshold" type="i">
      <default>25</default>
      <range min="0" max="100"/>
      <summary>Battery % at or above which the icon is yellow; below is red</summary>
    </key>
    <key name="rgb-enabled" type="b">
      <default>false</default>
      <summary>Manage the controller RGB lighting from this extension</summary>
    </key>
    <key name="rgb-brightness" type="i">
      <default>100</default>
      <range min="0" max="100"/>
      <summary>Overall LED brightness (percent)</summary>
    </key>
    <key name="rgb-zones" type="as">
      <default>["ffffff","ffffff","ffffff","ffffff"]</default>
      <summary>Per-zone LED colours as RRGGBB hex, ordered [Left, Right, Logo, Center]</summary>
    </key>
  </schema>
</schemalist>
